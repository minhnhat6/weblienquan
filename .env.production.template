# Production Environment Template
# Copy to .env.production and fill in values
# NEVER commit this file with real credentials!

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/weblienquan_prod?schema=public"

# ============================================
# SECURITY (Generate new for production!)
# ============================================
# Generate with: openssl rand -hex 32
SESSION_SECRET="REPLACE_WITH_64_HEX_CHARS"

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV="production"

# ============================================
# OPTIONAL: MONITORING
# ============================================
# SENTRY_DSN=""
# NEXT_PUBLIC_GA_ID=""

# ============================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASS=""
