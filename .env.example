# ============================================================
# TAPHOAACC - Environment Variables Example
# ============================================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to git!

# ============================================================
# ADMIN CREDENTIALS (CRITICAL - Change before deployment!)
# ============================================================
# ⚠️ These should be SERVER-SIDE ONLY (no NEXT_PUBLIC_ prefix)
# For production: Generate a bcrypt hash of your password
# node -e "require('bcryptjs').hash('YourSecurePassword123!', 10).then(console.log)"
ADMIN_USERNAME=admin
# ADMIN_INIT_PASS is DEPRECATED - Use ADMIN_PASSWORD_HASH instead in production
# ADMIN_INIT_PASS=change-this-password-immediately
ADMIN_PASSWORD_HASH=$2a$10$REPLACE_WITH_YOUR_BCRYPT_HASH

# ============================================================
# SESSION & SECURITY
# ============================================================
# JWT secret for admin session tokens (MUST be changed in production!)
# Generate a new one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Example: ptqdw/pYUe8X8Ov9t2hhD8ukPLOUHFNa5PxGknJVISo=
SESSION_SECRET=CHANGE_ME_TO_RANDOM_32_BYTE_BASE64_STRING

# ============================================================
# SITE CONFIGURATION (Client-visible)
# ============================================================
# These are safe to use NEXT_PUBLIC_ prefix
NEXT_PUBLIC_SITE_NAME=TaphoaACC
NEXT_PUBLIC_HOTLINE=0334622902

# ============================================================
# BUSINESS SETTINGS
# ============================================================
NEXT_PUBLIC_CONSIGNMENT_FEE=20
NEXT_PUBLIC_MIN_ORDER_FOR_SPIN=100000

# ============================================================
# DATABASE (Future - when migrating from localStorage)
# ============================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/weblienquan
# DATABASE_URL=mysql://user:password@localhost:3306/weblienquan

# ============================================================
# PAYMENT GATEWAY (Future)
# ============================================================
# VNPAY_TMN_CODE=your_tmn_code
# VNPAY_HASH_SECRET=your_hash_secret
# MOMO_PARTNER_CODE=your_partner_code
# MOMO_ACCESS_KEY=your_access_key

# ============================================================
# MONITORING & LOGGING
# ============================================================
# External log aggregation service (Logtail, Datadog, etc.)
# LOG_SERVICE_URL=https://logs.example.com/api/v1/logs
# LOG_SERVICE_TOKEN=your_log_service_token

# Force JSON logging format even in development
# LOG_FORMAT_JSON=true

# Sentry error tracking
# SENTRY_DSN=your_sentry_dsn

# Google Analytics
# NEXT_PUBLIC_GA_ID=your_google_analytics_id

# ============================================================
# RATE LIMITING (Optional)
# ============================================================
# Redis URL for distributed rate limiting (optional, falls back to in-memory)
# REDIS_URL=redis://localhost:6379
